---
interface Props {
  cols?: number;
  rows?: number;
  seed?: number;
  accent?: string;
  aspect?: string;
}

const {
  cols = 16,
  rows = 16,
  seed = 0,
  accent = 'var(--moss-bright)',
  aspect = '1/1',
} = Astro.props;

const cells = Array.from({ length: cols * rows }).map((_, i) => {
  const v = (Math.sin(i * 0.42 + seed) + Math.cos(i * 0.31 + seed * 0.7) + 2) / 4;
  let bg = 'transparent';
  if (v > 0.6) bg = accent;
  else if (v > 0.4) bg = 'var(--moss)';
  else if (v > 0.2) bg = 'var(--rule)';
  return bg;
});
---

<div
  class="matrix"
  style={`--cols:${cols}; --rows:${rows}; aspect-ratio:${aspect};`}
  aria-hidden="true"
>
  {cells.map((bg) => <div style={`background:${bg}`}></div>)}
</div>

<style>
  .matrix {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    grid-template-rows: repeat(var(--rows), 1fr);
    gap: 1px;
    background: var(--bg);
    padding: 6px;
    border: 1px solid var(--rule);
    width: 100%;
  }
  .matrix > div {
    min-width: 0;
    min-height: 0;
  }
</style>
