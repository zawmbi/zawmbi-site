---
/* Static stand-in for the prototype's drag-to-fill <image-slot> editor widget.
   Renders the styled empty-state box so the riso layout reads correctly;
   swap in a real <img> here once art is ready. */
interface Props {
  placeholder?: string;
  class?: string;
  style?: string;
}

const { placeholder = 'Drop an image', class: cls = '', style = '' } = Astro.props;
---

<div class:list={['image-slot', cls]} style={style}>
  <span class="image-slot__cap">{placeholder}</span>
</div>
