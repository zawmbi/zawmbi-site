---
/* Image placeholder that becomes a real <img> as soon as you give it a `src`.
   Drop your file in  public/attachments/  and set the src in index.astro
   (see the "YOUR IMAGES" block at the top of that file). With no src — or if the
   referenced file is missing — it renders the styled empty-state box so the
   layout still reads. */
interface Props {
  src?: string;
  alt?: string;
  placeholder?: string;
  class?: string;
  style?: string;
}

const { src = '', alt = '', placeholder = 'Drop an image', class: cls = '', style = '' } = Astro.props;
---

<div class:list={['image-slot', cls]} style={style}>
  <span class="image-slot__cap">{placeholder}</span>
  {src && <img class="image-slot__img" src={src} alt={alt} loading="lazy" onerror="this.remove()" />}
</div>
