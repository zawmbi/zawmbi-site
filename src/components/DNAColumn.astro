---
interface Props {
  height?: number;
  width?: number;
  opacity?: number;
}

const { height = 600, width = 60, opacity = 0.5 } = Astro.props;
const rungs = Math.floor(height / 24);

const segments = Array.from({ length: rungs }).map((_, i) => {
  const y = i * 24 + 8;
  const phase = (i * 0.55) % (Math.PI * 2);
  const x1 = width / 2 + Math.sin(phase) * (width / 2 - 8);
  const x2 = width / 2 - Math.sin(phase) * (width / 2 - 8);
  return { y, x1, x2 };
});
---

<svg
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  style={`opacity:${opacity}`}
  aria-hidden="true"
  class="dna"
>
  {segments.map(({ y, x1, x2 }) => (
    <g>
      <rect x={x1 - 3} y={y} width="6" height="6" fill="var(--moss)" />
      <rect x={x2 - 3} y={y} width="6" height="6" fill="var(--moss-bright)" />
      <line
        x1={x1}
        y1={y + 3}
        x2={x2}
        y2={y + 3}
        stroke="var(--faded)"
        stroke-width="1"
        stroke-dasharray="2 2"
      />
    </g>
  ))}
</svg>

<style>
  .dna {
    display: block;
  }
</style>
