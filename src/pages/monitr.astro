---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Carousel from '../components/Carousel.astro';
import {
  monitr,
  monitrStats,
  monitrTechTags,
  monitrThemes,
  monitrTour,
  monitrFeatures,
  monitrTech,
  monitrArch,
} from '../data/monitr';
---

<Base
  title="monitr · a live situation room for world events · Zawmbi Productions"
  description={monitr.blurb}
>
  <Nav />

  {/* ---------------- HERO ---------------- */}
  <section class="hero mon-hero" id="top">
    <div class="wrap">
      <a class="mon-back" href="/#apps">← Back to all apps</a>
      <div class="eyebrow" style="margin-top: 18px;">Flagship project</div>
      <h1 class="mon-title">monitr</h1>
      <p class="mon-tag">{monitr.tagline}</p>
      <p class="mon-blurb">{monitr.blurb}</p>
      <div class="mon-cta">
        <a class="btn btn-solid btn-lg" href={monitr.href} target="_blank" rel="noreferrer">Open monitr ↗</a>
        <div class="mon-meta">
          {monitr.platforms.map((p) => <span class="badge">{p}</span>)}
          <span class="badge badge-status">{monitr.status}</span>
        </div>
      </div>
      <div class="mon-tags">
        {monitrTechTags.map((t) => <span class="badge">{t}</span>)}
      </div>
      <div class="mon-stats">
        {monitrStats.map(([n, l]) => (
          <div class="mon-stat">
            <div class="mon-stat-n">{n}</div>
            <div class="mon-stat-l">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- GUIDED TOUR ---------------- */}
  <section class="section section-alt" id="tour">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">A guided tour</div>
        <h2 class="sec-title">See it in action</h2>
        <p class="sec-lead">From the live feed to the globe, the social layer, and the moderation back office. Flip through.</p>
      </div>
      <Carousel items={monitrTour} aspect="16 / 9" interval={4600} />
    </div>
  </section>

  {/* ---------------- THEME GALLERY ---------------- */}
  <section class="section" id="themes">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Nine colorways</div>
        <h2 class="sec-title">One interface,<br />nine moods</h2>
        <p class="sec-lead">Every theme re-tints the whole product from one token layer: panels, markers, overlays, and the globe itself.</p>
      </div>
      <Carousel items={monitrThemes} aspect="16 / 9" interval={4200} />
    </div>
  </section>

  {/* ---------------- WHAT IT DOES ---------------- */}
  <section class="section section-alt" id="features">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">What it does</div>
        <h2 class="sec-title">A whole situation<br />room, in a tab</h2>
        <p class="sec-lead">Six systems that each could be their own product, working together.</p>
      </div>
      <div class="feat-grid">
        {monitrFeatures.map(([t, d]) => (
          <div class="feat-card">
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- HOW IT'S BUILT ---------------- */}
  <section class="section" id="build">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">How it's built</div>
        <h2 class="sec-title">The engineering</h2>
        <p class="sec-lead">A hybrid of an always-on Dockerized backend and serverless, with security and cost treated as features.</p>
      </div>
      <div class="demo-list">
        {monitrTech.map(([t, d]) => (
          <div class="demo-row">
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>

      <div class="sec-head" style="margin: 56px 0 22px; max-width: none;">
        <h3 class="app-name" style="font-size: 24px;">Architecture at a glance</h3>
      </div>
      <div class="arch">
        <div class="arch-node"><h5>{monitrArch[0].title}</h5><p>{monitrArch[0].detail}</p></div>
        <span class="arch-arrow">→</span>
        <div class="arch-node"><h5>{monitrArch[1].title}</h5><p>{monitrArch[1].detail}</p></div>
        <span class="arch-arrow">→</span>
        <div class="arch-col">
          <div class="arch-node"><h5>{monitrArch[2].title}</h5><p>{monitrArch[2].detail}</p></div>
          <div class="arch-node"><h5>{monitrArch[3].title}</h5><p>{monitrArch[3].detail}</p></div>
        </div>
      </div>
    </div>
  </section>

  {/* ---------------- CTA ---------------- */}
  <section class="section section-alt" id="why">
    <div class="wrap">
      <div class="hire-cta pxc">
        <div>
          <h3 class="hire-cta-title">Want this kind of work?</h3>
          <p class="hire-cta-sub">Take something from an ambitious idea to shipped, security and infra included. Open to freelance, contract, or the right full-time role.</p>
        </div>
        <a class="btn btn-solid btn-lg" href="/#hire">Work with me</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
