---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Ghoul from '../components/Ghoul.astro';
import ImageSlot from '../components/ImageSlot.astro';
import Carousel from '../components/Carousel.astro';
import { socials } from '../data/site';
import { monitrThemes } from '../data/monitr';

/* ─────────────────────────── YOUR IMAGES ───────────────────────────
   Drop image files into  public/attachments/  then point each path here.
   A file at public/attachments/me.jpg is reachable as '/attachments/me.jpg'.
   Leave a value as '' to show the placeholder box instead.
   (monitr's screenshots live in src/data/monitr.ts → public/attachments/monitr/.)
   ──────────────────────────────────────────────────────────────────── */
const profilePhoto = '/attachments/lindapfp.jpg';   // hero trading-card photo (looks best ~4:3)
const makerAvatar = '/attachments/humanbehindit.jpg';    // small round avatar in the Studio section
const appShots = {
  attendize: '',           // phone screenshot (tall)
  syllabus: '',            // phone screenshot (tall)
} as Record<string, string>;

const apps = [
  {
    id: 'monitr',
    name: 'monitr',
    icon: 'mono',
    tagline: 'Keep tabs on what matters.',
    desc: 'A real-time dashboard for watching the world: live news, conflict, markets, elections, even satellites, all on one interactive globe you arrange yourself.',
    platforms: ['Web', 'Desktop', 'Mobile'],
    status: 'Live',
    href: 'https://monitr.xyz',
    cta: 'Open monitr',
    shot: 'wide',
  },
  {
    id: 'attendize',
    name: 'Attendize',
    icon: 'check',
    tagline: 'Attendance, minus the spreadsheet.',
    desc: 'Track your own attendance across classes, shifts, the gym, wherever you need to show up, in a couple of taps. See how your streak is really going.',
    platforms: ['iOS'],
    status: 'App Store',
    href: '#',
    cta: 'View on the App Store',
    shot: 'phone',
  },
];

/* In the lab — named, not shipped yet. Rendered in the #lab section.
   device: 'phone' = iPhone 6.9" shape, 'ipad' = iPad 13" shape.
   Drop screenshots in public/attachments/lab/ and set `shot`. The card links to `repo`. */
const labApps = [
  {
    name: 'BayFinder',
    platform: 'iOS',
    device: 'phone',
    repo: 'https://github.com/zawmbi/emt-app',
    shot: '',   // e.g. '/attachments/lab/bayfinder.png'
    hint: 'Exact coordinates and turn-by-turn directions to a hospital\'s emergency bay, built for EMTs who can\'t afford a wrong turn.',
  },
  {
    name: 'Animal Restaurant Tracker',
    platform: 'iOS',
    device: 'phone',
    repo: 'https://github.com/zawmbi/animal-restaurant-tracker-app',
    shot: '',   // e.g. '/attachments/lab/animal-restaurant.png'
    hint: 'A companion for the Animal Restaurant game that keeps track of your dishes, staff, and payouts in one place.',
  },
  {
    name: 'Syllabus to Calendar',
    platform: 'iOS',
    device: 'phone',
    repo: 'https://github.com/zawmbi/syllabus-to-calendar',
    shot: '',   // e.g. '/attachments/lab/syllabus.png'
    hint: 'Scan a syllabus and have every due date and exam added straight to your calendar.',
  },
];

const services = [
  ['Web apps, end to end', 'I handle the full process, from design and build through to deployment, whether the result is a dashboard, an internal tool, or a product that needs to work reliably from day one, like monitr.'],
  ['iOS apps', 'Native applications taken all the way through App Store review. Two are currently live, and there is room for yours.'],
  ['MVPs on a deadline', 'I turn an idea into a working, testable product within a few weeks, keeping the first version focused so that it reaches users quickly.'],
];

const steps = [
  ['Define the first version', 'We agree on what the first release genuinely needs to include, and what can wait until later.'],
  ['Build in stages', 'You see working software each week, rather than waiting for a single reveal at the end.'],
  ['Launch and refine', 'We release early, observe how the product is used, and improve the areas that matter most.'],
];

const tools = ['Swift & SwiftUI', 'React', 'TypeScript', 'Node.js', 'Design in Figma', 'App Store shipping'];

const principles = [
  ['Focused', 'Each app is built to do one job well, without unnecessary features or clutter.'],
  ['Shipped, then improved', 'I prioritize getting a working product into use over perfecting a plan in advance.'],
  ['Built for real use', 'Designed for people who are busy and value their time.'],
];

const marqueeItems = ['Indie software studio', 'Open for freelance', 'iOS + web', 'Three apps shipped', 'Built start to finish', 'Full-Stack'];
const marqueeRun = [...marqueeItems, ...marqueeItems];
---

<Base>
  <Nav />

  {/* ---------------- HERO ---------------- */}
  <section class="hero" id="top">
    <div class="hero-grid wrap">
      <div class="hero-copy">
        <div class="eyebrow">Indie studio + freelance · Chicago</div>
        <h1 class="hero-title" style="font-family: Inconsolata, ui-monospace, monospace;">Hi, I'm Linda!</h1>
        <p class="hero-sub">
          Zawmbi Productions is my solo studio. I design, build, and ship
          software start to finish. I develop iOS and webapps using a wide range of tools to best fit each client's personal needs.
        </p>
        <div class="hero-cta">
          <a class="btn btn-solid" href="#hire">Work with me</a>
          <a class="btn btn-ghost" href="#apps">Check out the apps →</a>
        </div>
        <div class="hero-ticker">
          <span class="dot"></span> <span class="tick-label">Open for freelance</span>
          <span class="tick-sep">·</span> shipping <strong>monitr</strong>, <strong>Attendize</strong> &amp; <strong>Syllabus&nbsp;to&nbsp;Calendar</strong>
        </div>
      </div>
      <aside class="hero-card pxc">
        <ImageSlot
          src={profilePhoto}
          alt="Photo of the founder of Zawmbi Productions"
          placeholder="Drop a photo of you"
          style="width: 100%; aspect-ratio: 4 / 3;"
        />
        <div>
          <div class="pc-name">Zawmbi</div>
          <div class="pc-role">Developer · Founder of Zawmbi Productions & monitr </div>
        </div>
        <div class="pc-list">
          <div class="pc-row"><span class="pc-k">Email</span><a class="pc-v" href="mailto:support@zawmbi.com">support@zawmbi.com</a></div>
          <div class="pc-row"><span class="pc-k">GitHub</span><a class="pc-v" href={socials.github} target="_blank" rel="noreferrer">github.com/zawmbi</a></div>
          <div class="pc-row"><span class="pc-k">LinkedIn</span><a class="pc-v" href={socials.linkedin} target="_blank" rel="noreferrer">linkedin.com/in/lindamansourr</a></div>
          <div class="pc-row"><span class="pc-k">Twitter</span><a class="pc-v" href={socials.twitter} target="_blank" rel="noreferrer">@zawmbiawmbi</a></div>
        </div>
        <div class="pc-avail"><span class="dot"></span> Open for freelance &amp; full-time</div>
      </aside>
    </div>
  </section>

  {/* ---------------- MARQUEE ---------------- */}
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {marqueeRun.map((s) => <span>{s}</span>)}
    </div>
  </div>

  {/* ---------------- APPS ---------------- */}
  <section class="section" id="apps">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">The apps</div>
        <div class="title-mascot">
          <h2 class="sec-title" style="font-family: Onest, system-ui, sans-serif;">What I've shipped</h2>
          <Ghoul kind="walk" width={76} label="Zawmbi zombie walking" />
        </div>
        <p class="sec-lead">Each of these began as a problem I wanted solved, so I built the solution and released it. Together they show that work here gets finished.</p>
      </div>
      <div class="approws">
        {apps.map((app, i) => (
          <article class:list={['approw', 'pxc', { 'approw-flip': i % 2 === 1 }]}>
            <div class="approw-media">
              {app.id === 'monitr' ? (
                <div style="width: 100%;">
                  <Carousel items={monitrThemes} aspect="16 / 10" interval={4200} />
                </div>
              ) : (
                <div class:list={['shot', `shot-${app.shot}`]}>
                  <ImageSlot
                    src={appShots[app.id] ?? ''}
                    alt={`${app.name} screenshot`}
                    placeholder={`Drop a ${app.name} screenshot`}
                    style="width: 100%; height: 100%;"
                  />
                </div>
              )}
            </div>
            <div class="approw-body">
              <div class="approw-head">
                <div class="app-icon pxc-sm">
                  {app.icon === 'check' && (
                    <svg viewBox="0 0 40 40" class="ag"><path d="M11 21 l6 6 l12 -14" /></svg>
                  )}
                  {app.icon === 'cal' && (
                    <svg viewBox="0 0 40 40" class="ag"><rect x="9" y="11" width="22" height="20" rx="3" /><path d="M9 17 H31 M15 8 V13 M25 8 V13" /></svg>
                  )}
                  {app.icon === 'mono' && (
                    <svg viewBox="0 0 40 40" class="ag"><path d="M8 26 l7 -9 l6 5 l5 -10 l6 8" /></svg>
                  )}
                </div>
                <div>
                  <h3 class="app-name">{app.name}</h3>
                  <div class="app-tag">{app.tagline}</div>
                </div>
              </div>
              <p class="app-desc">{app.desc}</p>
              <div class="app-meta">
                {app.platforms.map((p) => <span class="badge badge-plat">{p}</span>)}
                <span class="badge badge-status">{app.status}</span>
              </div>
              <div class="app-actions">
                <a
                  class="btn btn-solid app-link"
                  href={app.href}
                  target={app.href.startsWith('http') ? '_blank' : undefined}
                  rel="noreferrer"
                >{app.cta}</a>
                {app.id === 'monitr' && <a class="btn btn-ghost" href="/monitr">See the case study →</a>}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- HIRE ---------------- */}
  <section class="section section-alt" id="hire">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Work with me</div>
        <h2 class="sec-title">Let's build<br />something together</h2>
        <p class="sec-lead">I take on a limited number of freelance and contract projects between my own releases, and I'm open to the right full-time role.</p>
      </div>
      <div class="serv-grid">
        {services.map(([t, d], i) => (
          <div class="serv-card pxc">
            <span class="serv-no">{String(i + 1).padStart(2, '0')}</span>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
      <div class="toolbox pxc">
        <span class="tb-label">The toolbox</span>
        <div class="tb-chips">
          {tools.map((s) => <span class="tb-chip">{s}</span>)}
        </div>
      </div>
      <div class="how-strip pxc">
        {steps.map(([t, d], i) => (
          <div class="how-step">
            <span class="how-no">{i + 1}</span>
            <div>
              <div class="how-t">{t}</div>
              <div class="how-d">{d}</div>
            </div>
          </div>
        ))}
      </div>
      <div class="hire-cta pxc">
        <div>
          <h3 class="hire-cta-title">Have a project in mind?</h3>
          <p class="hire-cta-sub">Tell me what you're building, and I'll give you a straightforward assessment of whether I'm the right fit for it.</p>
        </div>
        <a class="btn btn-solid btn-lg" href="mailto:support@zawmbi.com?subject=Project%20inquiry">Email the studio</a>
      </div>
    </div>
  </section>

  {/* ---------------- STUDIO ---------------- */}
  <section class="section" id="studio">
    <div class="wrap studio-grid">
      <div class="studio-copy">
        <div class="eyebrow">The studio</div>
        <h2 class="sec-title">One person,<br />start to finish</h2>
        <p class="studio-p">
          Zawmbi Productions began with a recurring pattern: I kept encountering the
          same fixable problems and wanted better tools to deal with them. So I built
          those tools myself, and the ones that worked well ended up here.
        </p>
        <p class="studio-p">
          The apps differ on the surface, but they share a common principle. I believe
          software should respect the time of the people using it, and I keep that in
          mind across everything I build.
        </p>
        <div class="maker">
          <ImageSlot
            src={makerAvatar}
            alt="The maker behind Zawmbi Productions"
            placeholder="You"
            style="width: 60px; height: 60px; flex: none; border-radius: 50%;"
          />
          <div>
            <div class="maker-name">Linda Mansour</div>
            <div class="maker-role">Founder and developer of Zawmbi Productions</div>
          </div>
        </div>
      </div>
      <div class="principles">
        {principles.map(([t, d], i) => (
          <div class="principle pxc">
            <span class="principle-no">{String(i + 1).padStart(2, '0')}</span>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- LAB ---------------- */}
  <section class="section section-alt" id="lab">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">In the lab</div>
        <h2 class="sec-title">More on the way</h2>
        <p class="sec-lead">Several projects are currently in development. I'm not committing to release dates yet, but each one links to its GitHub repository, so you can follow the progress as it comes together.</p>
      </div>
      <div class="lab-grid">
        {labApps.map((app) => (
          <a class="lab-card lab-app pxc" href={app.repo} target="_blank" rel="noreferrer">
            <div class:list={['lab-shot', `lab-shot-${app.device}`]}>
              <ImageSlot
                src={app.shot}
                alt={`${app.name} screenshot`}
                placeholder={`${app.name} screenshot coming soon`}
                style="width: 100%; height: 100%;"
              />
            </div>
            <div class="lab-meta"><span class="badge badge-plat">{app.platform}</span></div>
            <div class="lab-name">{app.name}</div>
            <div class="lab-hint">{app.hint}</div>
            <span class="lab-follow">Follow progress on GitHub →</span>
          </a>
        ))}
        <a class="lab-card lab-cta pxc" href="mailto:support@zawmbi.com?subject=App%20idea">
          <div class="lab-plus">+</div>
          <div class="lab-name">Got an idea?</div>
          <div class="lab-hint">Tell me what you'd build →</div>
        </a>
      </div>
    </div>
  </section>

  {/* ---------------- NEWSLETTER ---------------- */}
  <section class="section notify" id="notify">
    <div class="wrap notify-inner">
      <span class="notify-mark"><Ghoul kind="head" width={58} /></span>
      <h2 class="sec-title notify-title">Get the next one first</h2>
      <p class="sec-lead">I send a brief email whenever I release something new, and I won't use your address for anything else.</p>
      <form class="notify-form" id="notify-form">
        <input class="notify-input" type="email" name="email" placeholder="you@email.com" aria-label="Email" required />
        <button class="btn btn-solid" type="submit">Notify me</button>
      </form>
      <div class="notify-done" id="notify-done" hidden>You're on the list. I'll be in touch. <span class="dot"></span></div>
      <div class="notify-foot">Or just email <a href="mailto:support@zawmbi.com">support@zawmbi.com</a></div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const form = document.getElementById('notify-form') as HTMLFormElement | null;
  const done = document.getElementById('notify-done');
  if (form && done) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem('email') as HTMLInputElement | null)?.value.trim();
      if (!email) return;
      form.hidden = true;
      done.hidden = false;
    });
  }
</script>
