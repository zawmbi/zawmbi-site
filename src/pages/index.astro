---
import Base from '../layouts/Base.astro';
import Mascot from '../components/Mascot.astro';
import ImageSlot from '../components/ImageSlot.astro';

/* ─────────────────────────── YOUR IMAGES ───────────────────────────
   Drop image files into  public/attachments/  then point each path here.
   A file at public/attachments/me.jpg is reachable as '/attachments/me.jpg'.
   Leave a value as '' to show the placeholder box instead.
   Example: const profilePhoto = '/attachments/me.jpg';
   ──────────────────────────────────────────────────────────────────── */
const profilePhoto = '/attachments/lindapfp.jpg';   // hero trading-card photo (looks best ~4:3)
const makerAvatar = '';    // small round avatar in the Studio section
const appShots = {
  monitr: '',              // wide screenshot (~16:10)
  attendize: '',           // phone screenshot (tall)
  syllabus: '',            // phone screenshot (tall)
} as Record<string, string>;

/* Social links — handles live here. */
const socials = {
  github: 'https://github.com/zawmbi',
  linkedin: 'https://linkedin.com/in/lindamansourr',
  twitter: 'https://twitter.com/zawmbiawmbi',
};

/* Brand glyphs (paths from simple-icons, 24×24 viewBox) for the footer row. */
const socialIcons = [
  {
    label: 'GitHub',
    href: socials.github,
    path: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  },
  {
    label: 'LinkedIn',
    href: socials.linkedin,
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    label: 'Twitter',
    href: socials.twitter,
    path: 'M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932L18.901 1.153Zm-1.291 19.49h2.039L6.486 3.24H4.298L17.61 20.643Z',
  },
];

const navLinks = [
  ['Apps', '#apps'],
  ['Hire', '#hire'],
  ['Studio', '#studio'],
];

const apps = [
  {
    id: 'monitr',
    name: 'monitr',
    icon: 'mono',
    tagline: 'Keep tabs on what matters.',
    desc: 'A clean dashboard for watching your sites and services: uptime, status, and alerts that look the same on your laptop and your phone.',
    platforms: ['Web', 'Desktop', 'Mobile'],
    status: 'Live',
    href: 'https://monitr.xyz',
    cta: 'Open monitr',
    shot: 'wide',
  },
  {
    id: 'attendize',
    name: 'Attendize',
    icon: 'check',
    tagline: 'Attendance, minus the spreadsheet.',
    desc: 'Track your own attendance across classes, shifts, the gym, wherever you need to show up, in a couple of taps. See how your streak is really going.',
    platforms: ['iOS'],
    status: 'App Store',
    href: '#',
    cta: 'View on the App Store',
    shot: 'phone',
  },
];

/* In the lab — named, not shipped yet. Rendered in the #lab section. */
const labApps = [
  {
    name: 'BayFinder',
    hint: 'Exact coordinates and turn-by-turn directions to a hospital\'s emergency bay, built for EMTs who can\'t afford a wrong turn.',
  },
  {
    name: 'Animal Restaurant Tracker',
    hint: 'Keep tabs on your Animal Restaurant progress: dishes, staff, and payouts, without the spreadsheet.',
  },
  {
    name: 'Syllabus to Calendar',
    hint: 'Scan a syllabus, get every due date and exam dropped into your calendar. Still in the oven.',
  },
];

const services = [
  ['Web apps, end to end', 'Design, build, deploy. Dashboards, internal tools, and products that need to work on day one, like monitr.'],
  ['iOS apps', 'Native apps shipped all the way through App Store review. Two live so far; yours can be the third.'],
  ['MVPs on a deadline', 'An idea turned into a real, testable product in weeks, scoped small on purpose so it actually ships.'],
];

const steps = [
  ['Scope it small', 'We find the sharpest version of v1, the thing worth building first.'],
  ['Build in slices', 'Working software every week, not a big reveal at the end.'],
  ['Ship, then sharpen', 'Launch early, watch real usage, fix what matters.'],
];

const tools = ['Swift & SwiftUI', 'React', 'TypeScript', 'Node.js', 'Design in Figma', 'App Store shipping'];

const principles = [
  ['Small on purpose', 'No bloat, no settings screen with 40 tabs. One job, done cleanly.'],
  ['Ships, then sharpens', 'Real apps in real hands beats a perfect roadmap on a whiteboard.'],
  ['Built for your actual life', 'Made for people who are busy and broke on time.'],
];

const marqueeItems = ['Indie software studio', 'Open for freelance', 'iOS + web', 'Three apps shipped', 'Built start to finish', 'Hi, I\'m Linda!'];
const marqueeRun = [...marqueeItems, ...marqueeItems];
---

<Base>
  {/* ---------------- NAV ---------------- */}
  <header class="nav">
    <a class="brand" href="#top">
      <span class="brand-mark"><Mascot kind="head" width={38} /></span>
      <span class="wordmark">Zawmbi</span>
      <span class="wordmark wordmark-sub2">Productions</span>
    </a>
    <nav class="nav-links">
      {navLinks.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
    <a class="btn btn-solid nav-cta" href="#hire">Start a project</a>
  </header>

  {/* ---------------- HERO ---------------- */}
  <section class="hero" id="top">
    <div class="hero-grid wrap">
      <div class="hero-copy">
        <div class="eyebrow">Indie studio + freelance · est 2026</div>
        <h1 class="hero-title" style="font-family: Inconsolata, ui-monospace, monospace;">Small apps.<br />Serious craft.</h1>
        <p class="hero-sub">
          Zawmbi Productions is my solo studio. I design, build, and ship
          software start to finish. Two apps live, more in the lab, and the
          same care goes into client work.
        </p>
        <div class="hero-cta">
          <a class="btn btn-solid" href="#hire">Work with me</a>
          <a class="btn btn-ghost" href="#apps">See the apps →</a>
        </div>
        <div class="hero-ticker">
          <span class="dot"></span> <span class="tick-label">Open for freelance</span>
          <span class="tick-sep">·</span> shipping <strong>monitr</strong>, <strong>Attendize</strong> &amp; <strong>Syllabus&nbsp;to&nbsp;Calendar</strong>
        </div>
      </div>
      <aside class="hero-card pxc">
        <ImageSlot
          src={profilePhoto}
          alt="Photo of the founder of Zawmbi Productions"
          placeholder="Drop a photo of you"
          style="width: 100%; aspect-ratio: 4 / 3;"
        />
        <div>
          <div class="pc-name">Zawmbi</div>
          <div class="pc-role">Developer · designer · founder, Zawmbi Productions</div>
        </div>
        <div class="pc-list">
          <div class="pc-row"><span class="pc-k">Email</span><a class="pc-v" href="mailto:support@zawmbi.com">support@zawmbi.com</a></div>
          <div class="pc-row"><span class="pc-k">GitHub</span><a class="pc-v" href={socials.github} target="_blank" rel="noreferrer">github.com/zawmbi</a></div>
          <div class="pc-row"><span class="pc-k">LinkedIn</span><a class="pc-v" href={socials.linkedin} target="_blank" rel="noreferrer">linkedin.com/in/lindamansourr</a></div>
          <div class="pc-row"><span class="pc-k">Twitter</span><a class="pc-v" href={socials.twitter} target="_blank" rel="noreferrer">@zawmbiawmbi</a></div>
        </div>
        <div class="pc-avail"><span class="dot"></span> Open for freelance &amp; full-time</div>
      </aside>
    </div>
  </section>

  {/* ---------------- MARQUEE ---------------- */}
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {marqueeRun.map((s) => <span>{s}</span>)}
    </div>
  </div>

  {/* ---------------- APPS ---------------- */}
  <section class="section" id="apps">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">The apps</div>
        <h2 class="sec-title" style="font-family: Onest, system-ui, sans-serif;">Shipped &amp; alive</h2>
        <p class="sec-lead">Each one solves a single annoying thing, properly. Proof that things here get finished.</p>
      </div>
      <div class="approws">
        {apps.map((app, i) => (
          <article class:list={['approw', 'pxc', { 'approw-flip': i % 2 === 1 }]}>
            <div class="approw-media">
              <div class:list={['shot', `shot-${app.shot}`]}>
                <ImageSlot
                  src={appShots[app.id] ?? ''}
                  alt={`${app.name} screenshot`}
                  placeholder={`Drop a ${app.name} screenshot`}
                  style="width: 100%; height: 100%;"
                />
              </div>
            </div>
            <div class="approw-body">
              <div class="approw-head">
                <div class="app-icon pxc-sm">
                  {app.icon === 'check' && (
                    <svg viewBox="0 0 40 40" class="ag"><path d="M11 21 l6 6 l12 -14" /></svg>
                  )}
                  {app.icon === 'cal' && (
                    <svg viewBox="0 0 40 40" class="ag"><rect x="9" y="11" width="22" height="20" rx="3" /><path d="M9 17 H31 M15 8 V13 M25 8 V13" /></svg>
                  )}
                  {app.icon === 'mono' && (
                    <svg viewBox="0 0 40 40" class="ag"><path d="M8 26 l7 -9 l6 5 l5 -10 l6 8" /></svg>
                  )}
                </div>
                <div>
                  <h3 class="app-name">{app.name}</h3>
                  <div class="app-tag">{app.tagline}</div>
                </div>
              </div>
              <p class="app-desc">{app.desc}</p>
              <div class="app-meta">
                {app.platforms.map((p) => <span class="badge badge-plat">{p}</span>)}
                <span class="badge badge-status">{app.status}</span>
              </div>
              <a
                class="btn btn-solid app-link"
                href={app.href}
                target={app.href.startsWith('http') ? '_blank' : undefined}
                rel="noreferrer"
              >{app.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- HIRE ---------------- */}
  <section class="section section-alt" id="hire">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Work with me</div>
        <h2 class="sec-title">Bring me your<br />annoying problem</h2>
        <p class="sec-lead">I take on a small number of freelance and contract projects between releases, and I'm open to the right full-time role.</p>
      </div>
      <div class="serv-grid">
        {services.map(([t, d], i) => (
          <div class="serv-card pxc">
            <span class="serv-no">{String(i + 1).padStart(2, '0')}</span>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
      <div class="toolbox pxc">
        <span class="tb-label">The toolbox</span>
        <div class="tb-chips">
          {tools.map((s) => <span class="tb-chip">{s}</span>)}
        </div>
      </div>
      <div class="how-strip pxc">
        {steps.map(([t, d], i) => (
          <div class="how-step">
            <span class="how-no">{i + 1}</span>
            <div>
              <div class="how-t">{t}</div>
              <div class="how-d">{d}</div>
            </div>
          </div>
        ))}
      </div>
      <div class="hire-cta pxc">
        <div>
          <h3 class="hire-cta-title">Have a project in mind?</h3>
          <p class="hire-cta-sub">Tell me what you're building. You'll get an honest take, not a sales pitch.</p>
        </div>
        <a class="btn btn-solid btn-lg" href="mailto:support@zawmbi.com?subject=Project%20inquiry">Email the studio</a>
      </div>
    </div>
  </section>

  {/* ---------------- STUDIO ---------------- */}
  <section class="section" id="studio">
    <div class="wrap studio-grid">
      <div class="studio-copy">
        <div class="eyebrow">The studio</div>
        <h2 class="sec-title">One human.<br />No filler.</h2>
        <p class="studio-p">
          Zawmbi Productions is what happens when one developer keeps running into
          small, fixable annoyances and refuses to just live with them. So I build
          the tool, and if it's good, it ships here.
        </p>
        <p class="studio-p">
          Everything under the Zawmbi roof shares a spine: fast, honest, and a little
          bit weird. Separate products, one stubborn point of view about how software
          should treat your time.
        </p>
        <div class="maker">
          <ImageSlot
            src={makerAvatar}
            alt="The maker behind Zawmbi Productions"
            placeholder="You"
            style="width: 60px; height: 60px; flex: none; border-radius: 50%;"
          />
          <div>
            <div class="maker-name">The human behind it</div>
            <div class="maker-role">Founder · designer · the one fixing the bug at 2am</div>
          </div>
        </div>
      </div>
      <div class="principles">
        {principles.map(([t, d], i) => (
          <div class="principle pxc">
            <span class="principle-no">{String(i + 1).padStart(2, '0')}</span>
            <h4>{t}</h4>
            <p>{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ---------------- LAB ---------------- */}
  <section class="section section-alt" id="lab">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">In the lab</div>
        <h2 class="sec-title">More on the way</h2>
        <p class="sec-lead">A couple of things are shambling toward the light. No promises on dates.</p>
      </div>
      <div class="lab-grid">
        {labApps.map((app) => (
          <div class="lab-card pxc">
            <div class="lab-lock">◴</div>
            <div class="lab-name">{app.name}</div>
            <div class="lab-hint">{app.hint}</div>
          </div>
        ))}
        <a class="lab-card lab-cta pxc" href="mailto:support@zawmbi.com?subject=App%20idea">
          <div class="lab-plus">+</div>
          <div class="lab-name">Got an idea?</div>
          <div class="lab-hint">Tell me what you'd build →</div>
        </a>
      </div>
    </div>
  </section>

  {/* ---------------- NEWSLETTER ---------------- */}
  <section class="section notify" id="notify">
    <div class="wrap notify-inner">
      <span class="notify-mark"><Mascot kind="head" width={58} /></span>
      <h2 class="sec-title notify-title">Get the next one first</h2>
      <p class="sec-lead">One short email when something new ships. No spam, no growth hacking, no nonsense.</p>
      <form class="notify-form" id="notify-form">
        <input class="notify-input" type="email" name="email" placeholder="you@email.com" aria-label="Email" required />
        <button class="btn btn-solid" type="submit">Notify me</button>
      </form>
      <div class="notify-done" id="notify-done" hidden>You're on the list. I'll be in touch. <span class="dot"></span></div>
      <div class="notify-foot">Or just email <a href="mailto:support@zawmbi.com">support@zawmbi.com</a></div>
    </div>
  </section>

  {/* ---------------- FOOTER ---------------- */}
  <footer class="footer">
    <div class="wrap footer-grid">
      <div class="footer-brand">
        <a class="brand" href="#top">
          <span class="brand-mark"><Mascot kind="head" width={32} /></span>
          <span class="wordmark">Zawmbi</span>
        </a>
        <p class="footer-tag">Small apps, zero busywork.</p>
        <div class="footer-socials">
          {socialIcons.map((s) => (
            <a href={s.href} target="_blank" rel="noreferrer" aria-label={s.label}>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>
      <div class="footer-cols">
        <div class="footer-col">
          <h5>Apps</h5>
          <a href="#apps">monitr</a><a href="#apps">Attendize</a><a href="#apps">Syllabus to Calendar</a>
        </div>
        <div class="footer-col">
          <h5>Work</h5>
          <a href="#hire">Hire me</a><a href="#studio">About</a><a href="#lab">In the lab</a>
        </div>
        <div class="footer-col">
          <h5>Say hi</h5>
          <a href="mailto:support@zawmbi.com">support@zawmbi.com</a>
          <a href={socials.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={socials.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={socials.twitter} target="_blank" rel="noreferrer">Twitter</a>
          <a href="#notify">Get notified</a>
        </div>
      </div>
    </div>
    <div class="wrap footer-base">
      <span>© 2026 Zawmbi Productions</span>
      <span>zawmbi.com</span>
    </div>
  </footer>
</Base>

<script>
  const form = document.getElementById('notify-form') as HTMLFormElement | null;
  const done = document.getElementById('notify-done');
  if (form && done) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem('email') as HTMLInputElement | null)?.value.trim();
      if (!email) return;
      form.hidden = true;
      done.hidden = false;
    });
  }
</script>
